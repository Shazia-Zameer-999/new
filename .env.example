# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Existing ---
RESEND_API_KEY=""
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/zewarish?retryWrites=true&w=majority"
SECRET_KEY="change-me-to-a-long-random-string"
ADMIN_PASSWORD="change-me"

# --- Cloudinary (Gallery admin image uploads) ---
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional: folder inside your Cloudinary account where gallery photos are stored.
CLOUDINARY_GALLERY_FOLDER="zewarish/gallery"
